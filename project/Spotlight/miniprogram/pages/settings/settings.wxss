/* pages/settings/settings.wxss */
/* 设置页样式 */

.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  background-color: #16213e;
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #a0a0a0;
}

/* 场景卡片 */
.scene-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  transition: all 0.2s ease;
}

.scene-card:active {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.06) 100%);
}

.scene-info {
  display: flex;
  align-items: center;
}

.scene-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.scene-details {
  display: flex;
  flex-direction: column;
}

.scene-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.scene-desc {
  font-size: 24rpx;
  color: #a0a0a0;
}

/* 阈值显示 */
.threshold-display {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.threshold-value-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, rgba(74, 158, 255, 0.15) 0%, rgba(74, 158, 255, 0.05) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(74, 158, 255, 0.2);
}

.threshold-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #4a9eff;
  line-height: 1;
}

.threshold-unit {
  font-size: 28rpx;
  color: #a0a0a0;
  margin-left: 4rpx;
}

.slider-wrapper {
  margin: 0 -4rpx;
  padding: 0 8rpx;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 0 8rpx;
}

.slider-label {
  font-size: 22rpx;
  color: #a0a0a0;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
}

.setting-item:active {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.04) 100%);
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.setting-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}

.setting-icon-wrapper.vibrate {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.2) 0%, rgba(250, 173, 20, 0.1) 100%);
  border: 1rpx solid rgba(250, 173, 20, 0.3);
}

.setting-icon-wrapper.sound {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.2) 0%, rgba(82, 196, 26, 0.1) 100%);
  border: 1rpx solid rgba(82, 196, 26, 0.3);
}

.setting-icon-wrapper.visual {
  background: linear-gradient(135deg, rgba(74, 158, 255, 0.2) 0%, rgba(74, 158, 255, 0.1) 100%);
  border: 1rpx solid rgba(74, 158, 255, 0.3);
}

.setting-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}

.setting-desc {
  font-size: 22rpx;
  color: #a0a0a0;
}

/* 间隔显示 */
.interval-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
  gap: 8rpx;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.15) 0%, rgba(250, 173, 20, 0.05) 100%);
  border-radius: 20rpx;
  border: 2rpx solid rgba(250, 173, 20, 0.2);
}

.interval-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #faad14;
  line-height: 1;
}

.interval-unit {
  font-size: 28rpx;
  color: #a0a0a0;
}

/* 重置按钮 */
.btn-reset {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.15) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: #ff7875;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid rgba(255, 77, 79, 0.25);
  border-radius: 16rpx;
  margin-top: 24rpx;
  transition: all 0.2s ease;
}

.btn-reset:active {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.25) 0%, rgba(255, 77, 79, 0.1) 100%);
  transform: scale(0.99);
}

/* 场景选择器遮罩 */
.scene-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.scene-picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.scene-picker {
  width: 100%;
  background: linear-gradient(180deg, #1e2a4a 0%, #16213e 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.scene-picker-mask.show .scene-picker {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.picker-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.picker-close:active {
  background-color: rgba(255, 255, 255, 0.15);
}

.picker-options {
  padding: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.picker-option:active {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.04) 100%);
}

.picker-option.active {
  background: linear-gradient(135deg, rgba(74, 158, 255, 0.15) 0%, rgba(74, 158, 255, 0.05) 100%);
  border-color: rgba(74, 158, 255, 0.4);
}

.picker-option-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.picker-option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.picker-option-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
}

.picker-option-desc {
  font-size: 24rpx;
  color: #a0a0a0;
}

.picker-option-threshold {
  font-size: 22rpx;
  color: #4a9eff;
  margin-top: 4rpx;
}

/* 滚动条样式 */
.picker-options::-webkit-scrollbar {
  width: 4rpx;
}

.picker-options::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 2rpx;
}
